{
  "version": 2,
  "installCommand": "git clone https://github.com -b stable && ./flutter/bin/flutter doctor",
  "buildCommand": "./flutter/bin/flutter config --enable-web && ./flutter/bin/flutter build web --release",
  "outputDirectory": "build/web",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
