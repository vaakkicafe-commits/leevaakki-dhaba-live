{
  "version": 2,
  "installCommand": "git clone --depth 1 https://github.com -b 3.7.9 ./flutter-sdk && ./flutter-sdk/bin/flutter config --enable-web",
  "buildCommand": "./flutter-sdk/bin/flutter build web --release",
  "outputDirectory": "build/web",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
