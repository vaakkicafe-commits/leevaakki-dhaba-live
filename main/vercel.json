{
  "version": 2,
  "installCommand": "git clone --depth 1 https://github.com/flutter/flutter.git -b stable",
  "buildCommand": "./flutter/bin/flutter config --enable-web && ./flutter/bin/flutter build web --release",
  "outputDirectory": "build/web",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
