{
  "version": 2,
  "installCommand": "git clone --depth 1 https://github.com -b stable $HOME/flutter-sdk",
  "buildCommand": "$HOME/flutter-sdk/bin/flutter config --enable-web && $HOME/flutter-sdk/bin/flutter build web --release",
  "outputDirectory": "build/web",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
